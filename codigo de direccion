//modificacion exitosa//
// Pines de control del motor
const int IN1 = 8;
const int IN2 = 9;
const int ENA = 10;  // PWM para controlar velocidad

void setup() {
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(ENA, OUTPUT);
}

void loop() {
  // Girar a la derecha (horario)
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  analogWrite(ENA, 200); // Velocidad media
  delay(2000); // Gira por 2 segundos

  // Detener motor
  digitalWrite(ENA, LOW);
  delay(1000);

  // Girar a la izquierda 
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  analogWrite(ENA, 200); // Velocidad media
  delay(2000); // Gira por 2 segundos

  // Detener motor
  digitalWrite(ENA, LOW);
  delay(1000);
}
